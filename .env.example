APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated origins allowed to call this API from browsers (Nuxt admin on another host).
# No wildcard; use explicit HTTPS/HTTP URLs. Firebase uses Bearer tokens (supports_credentials stays false in config).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=

# Optional cache for preflight responses (seconds).
# CORS_MAX_AGE=0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Database queue: required for queued mail (e.g. AdminAccessRequestedMail). Run a worker in dev/prod:
#   php artisan queue:work --tries=3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# DigitalOcean Spaces (S3-compatible). Laravel is the only writer; never commit secrets.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=ixora-buckets
DO_SPACES_REGION=tor1
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://ixora-buckets.tor1.cdn.digitaloceanspaces.com

VITE_APP_NAME="${APP_NAME}"

# Admin access approval (reviewer inbox for signed approve/reject links)
ADMIN_ACCESS_REVIEW_EMAIL=lucas_brito@outlook.com
# ADMIN_ACCESS_SIGNED_URL_TTL_DAYS=7

# Firebase Admin (Kreait): use ONE of these credential modes.
#
# Preferred on App Platform / CI — discrete env vars (no inline JSON blobs):
# FIREBASE_TYPE=service_account
# FIREBASE_PROJECT_ID=your-gcp-project
# FIREBASE_PRIVATE_KEY_ID=...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@....iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=...
# FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
# FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
#
# PEM in .env uses real newlines inside quotes OR literal \n escapes (handled at runtime).
#
# Deprecated — single-line JSON blob (escaped quotes are brittle in some hosts):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Local development — path to downloaded key JSON file (relative paths use Laravel base_path):
FIREBASE_CREDENTIALS=

#
# Native Android offline QA fixtures (front_vibes WDIO)
# ------------------------------------------------------------------
# After the user exists in `users` (mobile sign-in → /api/auth/sync), run once per environment:
#   php artisan ixora:seed-native-offline-qa --email=you@example.com
# Or set the email here and omit --email:
# NATIVE_QA_FIXTURE_USER_EMAIL=
#
# Optional HTTPS MP3 URLs for the two fixture layers (defaults: SoundHelix public samples):
# NATIVE_QA_FIXTURE_SOUND_URL_A=
# NATIVE_QA_FIXTURE_SOUND_URL_B=
#
# Debug (non-production only): authenticated GET /api/debug/me → id, email, firebase_uid, vibes_count.
# The route is not registered when APP_ENV=production — no separate env toggle.
